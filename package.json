{
  "name": "tasks-1",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,app -c blue,green \"npm run dev:api\" \"npm run dev:app\"",
    "dev:api": "npm run dev --workspace=api",
    "dev:app": "npm run dev --workspace=app",
    "build": "npm run build --workspace=app",
    "install:all": "npm install --workspaces",
    "deploy": "npm run build && npm run deploy --workspace=app"
  },
  "workspaces": [
    "api",
    "app"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
